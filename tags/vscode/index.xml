      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Azure Blue&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;#007fff&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;Azure 雲端專案&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
