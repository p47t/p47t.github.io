      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Google Blue&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;#4285f4&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;Google Cloud 或 Firebase 專案&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;LinkedIn Blue&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;#0a66c2&lt;/code&gt;&lt;/td&gt;
